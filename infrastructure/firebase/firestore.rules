rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'midhunjr2222@gmail.com'
      );
    }

    // Products, Categories, Brands, Slideshow: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /slideshow/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Coupons & Settings: Admin only
    match /coupons/{couponId} {
      allow read, write: if isAdmin();
    }
    match /settings/{settingId} {
      allow read: if true; // Public can see banner/tax
      allow write: if isAdmin();
    }

    // Orders: Admin read/write, Users can see their own
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.user_id == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Users: Admin read/write, Users can see/edit their own profile
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);

      match /cart/{itemId} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      }
    }
  }
}
